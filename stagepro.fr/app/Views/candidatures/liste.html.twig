{% extends "layout.html.twig" %}

{# On détermine le rôle pour adapter l'affichage #}
{% set is_management = session.user.role in ['admin', 'pilote'] %}

{% block title %}
    {{ is_management ? 'Gestion des candidatures' : 'Mes candidatures' }} | StagePro
{% endblock %}

{% block content %}
<section>
    <h1>{{ is_management ? 'Gestion des candidatures' : 'Mes candidatures' }}</h1>
    <p style="color: var(--text-muted);">
        {{ is_management 
            ? "Retrouvez ici l’ensemble des candidatures déposées sur la plateforme." 
            : "Retrouvez ici les offres auxquelles vous avez postulé et le détail de vos dossiers envoyés." 
        }}
    </p>
</section>

<section style="margin-top: 2rem;">
    {% if candidatures is empty %}
        <div style="background: var(--surface); padding: 3rem; border-radius: 12px; text-align: center; border: 1px solid var(--border);">
            <p style="font-size: 1.1rem; color: var(--text-muted);">Aucune candidature trouvée.</p>
            {% if not is_management %}
                <a href="index.php?page=offres" class="btn-cta" style="display: inline-block; margin-top: 1rem; text-decoration: none;">
                    Voir les offres disponibles
                </a>
            {% endif %}
        </div>
    {% else %}
        <div class="container-espaces" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
            {% for c in candidatures %}
                {# Logique des badges de statut #}
                {% set badge = { 'label': 'En attente', 'bg': '#fef3c7', 'color': '#92400e' } %}
                {% if c.statut == 'acceptee' %}
                    {% set badge = { 'label': 'Acceptée', 'bg': '#dcfce7', 'color': '#166534' } %}
                {% elseif c.statut == 'refusee' %}
                    {% set badge = { 'label': 'Refusée', 'bg': '#fee2e2', 'color': '#991b1b' } %}
                {% endif %}

                <article class="card candidature-card">
                    <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: flex-start; margin-bottom: 1rem;">
                        <h3 style="color: var(--accent-blue); margin: 0; font-size: 1.2rem;">
                            {{ c.offre_titre }}
                        </h3>
                        <span style="background: {{ badge.bg }}; color: {{ badge.color }}; padding: 4px 10px; border-radius: 999px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; white-space: nowrap;">
                            {{ badge.label }}
                        </span>
                    </div>

                    <div style="font-size: 0.95rem; line-height: 1.6;">
                        <p style="margin: 0;"><strong>Entreprise :</strong> {{ c.entreprise_nom }}</p>
                        
                        {# Affichage du nom du candidat uniquement pour Admin/Pilote #}
                        {% if is_management %}
                            <p style="margin: 0.5rem 0 0 0;">
                                <strong>Candidat :</strong> {{ c.etudiant_prenom }} {{ c.etudiant_nom }}
                            </p>
                        {% endif %}
                    </div>

                    <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 0.8rem; color: var(--text-muted);">
                             {{ c.created_at|date("d/m/Y à H:i") }}
                        </span>
                        <span style="font-size: 0.8rem; font-weight: bold; color: var(--accent-blue); text-transform: uppercase;">
                            Détails &rarr;
                        </span>
                    </div>

                    {# Lien étendu pour rendre toute la carte cliquable #}
                    <a href="index.php?page=candidature-detail&id={{ c.id }}" class="lien-etendu" title="Voir les détails"></a>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</section>

<style>
.candidature-card {
    position: relative; 
    transition: all 0.25s ease; 
    border: 1px solid var(--border); 
    padding: 1.5rem; 
    border-radius: 12px; 
    background: var(--surface);
    display: flex;
    flex-direction: column;
}

.candidature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    border-color: var(--accent-blue);
}

.lien-etendu {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
}
</style>
{% endblock %}