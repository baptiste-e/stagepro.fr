{% extends "layout.html.twig" %}

{% block title %}Connexion | StagePro{% endblock %}

{% block content %}
<section style="max-width: 500px; margin: 3rem auto; background: var(--surface); padding: 2rem; border: 1px solid var(--border); border-radius: 8px;">
    <h1>Connexion</h1>
    <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Connectez-vous à votre espace StagePro.</p>

    {# Gestion de l'affichage de l'erreur #}
    {% if erreur %}
        <div style="background: #ffdede; color: #a10000; padding: 12px; border-radius: 6px; margin-bottom: 1rem; border: 1px solid #ffbaba;">
            {{ erreur }}
        </div>
    {% endif %}

    <form action="index.php?page=login" method="post">
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Email</label>
            <input type="email" id="email" name="email" required style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border); box-sizing: border-box;">
        </div>

        <div class="form-group" style="margin-bottom: 2rem;">
            <label for="mot_de_passe" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Mot de passe</label>
            <input type="password" id="mot_de_passe" name="mot_de_passe" required style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border); box-sizing: border-box;">
        </div>

        <button type="submit" style="width: 100%; background: var(--accent-blue); color: white; padding: 1rem; border: none; border-radius: 6px; cursor: pointer; font-weight: 700; font-size: 1rem;">
            Se connecter
        </button>
    </form>
</section>
{% endblock %}