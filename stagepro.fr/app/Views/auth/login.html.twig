{% extends "layout.html.twig" %}

{% block title %}Connexion | StagePro{% endblock %}

{% block content %}
<section style="max-width: 500px; margin: 3rem auto; background: var(--surface); padding: 2rem; border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
    <h1 style="margin-top: 0;">Connexion</h1>
    <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Connectez-vous à votre espace StagePro.</p>

    {# Affichage du message d'erreur si les identifiants sont incorrects #}
    {% if erreur %}
        <div style="background: #ffdede; color: #a10000; padding: 12px; border-radius: 6px; margin-bottom: 1.5rem; border: 1px solid #ffbaba; font-size: 0.9rem; text-align: center;">
            <strong>Erreur :</strong> {{ erreur }}
        </div>
    {% endif %}

    <form action="index.php?page=login" method="post">
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem;">Email</label>
            <input type="email" id="email" name="email" placeholder="votre@email.fr" required 
                   style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--text); box-sizing: border-box; font-size: 1rem;">
        </div>

        <div class="form-group" style="margin-bottom: 2rem;">
            <label for="mot_de_passe" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem;">Mot de passe</label>
            <input type="password" id="mot_de_passe" name="mot_de_passe" placeholder="••••••••" required 
                   style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--text); box-sizing: border-box; font-size: 1rem;">
        </div>

        <button type="submit" style="width: 100%; background: var(--accent-blue); color: white; padding: 1rem; border: none; border-radius: 6px; cursor: pointer; font-weight: 700; font-size: 1rem; transition: filter 0.2s;">
            Se connecter
        </button>
    </form>
    
    <div style="margin-top: 1.5rem; text-align: center; font-size: 0.85rem; color: var(--text-muted);">
        <p>Problème d'accès ? Contactez un pilote ou l'administrateur.</p>
    </div>
</section>
{% endblock %}