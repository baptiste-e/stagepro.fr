<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ titre_page|default('StagePro') }}{% endblock %}</title>
    <link rel="stylesheet" href="styles.css">

    <link rel="manifest" href="manifest.json">

    {# =========================
       COOKIES UTILES
       ========================= #}
    {% if cookie_consent == 'accepted' %}
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                let visits = parseInt(localStorage.getItem('visits') || '0');
                localStorage.setItem('visits', visits + 1);

                let pages = JSON.parse(localStorage.getItem('pages') || '[]');
                pages.push(window.location.pathname);
                localStorage.setItem('pages', JSON.stringify(pages));

                console.log("Cookies activés :", visits + 1);
            });
        </script>
    {% endif %}
</head>

<body>

{# ================= HEADER ================= #}
<header style="background:#fff; border-bottom:1px solid #ddd; padding:15px;">
    <h1><a href="index.php?page=home" style="color:#2563eb;">StagePro</a></h1>
</header>

{# ================= COOKIE BANNER ================= #}
{% if cookie_consent is not defined or cookie_consent is null %}
<div id="cookie-banner" style="
    position: fixed;
    bottom:0;
    left:0;
    width:100%;
    background:#f9fafb;
    border-top:1px solid #ddd;
    padding:20px;
    z-index:9999;
">

    <p style="margin-bottom:15px;">
        Ce site utilise des cookies pour améliorer votre expérience.
    </p>

    <div style="display:flex; gap:10px;">
        <a href="index.php?page=cookie-accept" style="
            background:#2563eb;
            color:white;
            padding:10px 20px;
            border-radius:6px;
            text-decoration:none;
            font-weight:600;
        ">Accepter</a>

        <a href="index.php?page=cookie-refuse" style="
            background:#ef4444;
            color:white;
            padding:10px 20px;
            border-radius:6px;
            text-decoration:none;
            font-weight:600;
        ">Refuser</a>

        <button onclick="toggleCookies()" style="
            border:1px solid #2563eb;
            color:#2563eb;
            background:white;
            padding:10px 20px;
            border-radius:6px;
            font-weight:600;
        ">
            Personnaliser
        </button>
    </div>

    <div id="cookie-settings" style="display:none; margin-top:15px;">
        <form method="get" action="index.php">
            <input type="hidden" name="page" value="cookie-accept">

            <label>
                <input type="checkbox" checked disabled>
                Essentiels
            </label><br>

            <label>
                <input type="checkbox" name="stats" checked>
                Statistiques
            </label><br><br>

            <button type="submit">Valider</button>
        </form>
    </div>
</div>

<script>
function toggleCookies(){
    let el = document.getElementById('cookie-settings');
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>
{% endif %}

{# ================= CONTENT ================= #}
<main style="padding:40px;">
    {% block content %}{% endblock %}
</main>

{# ================= FOOTER ================= #}
<footer style="text-align:center; padding:20px; background:#f3f4f6;">
    © 2026 StagePro  
    | <a href="index.php?page=cookie-reset">Gérer les cookies</a>
</footer>

</body>
</html>