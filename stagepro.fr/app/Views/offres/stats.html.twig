{% extends "layout.html.twig" %}

{% block content %}
{# ... Header Stats ... #}
<section style="margin-top: 3rem;">
  <div class="container-espaces" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem;">
    <article class="card" style="border-top: 4px solid var(--accent);">
      <h3>Offres</h3>
      <p style="font-size: 2.5rem;">{{ totalOffres|default(0) }}</p>
    </article>
    {# ... Autres cards ... #}
  </div>
</section>

<section style="margin-top: 4rem; background: var(--surface); padding: 2rem; border-radius: 8px;">
  <h2>Répartition par localité</h2>
  {% for ligne in statsLocalite %}
    <div style="display: grid; grid-template-columns: 180px 1fr 60px; gap: 1rem; align-items: center; margin-bottom: 1rem;">
      <div>{{ ligne.localite|default('Inconnu') }}</div>
      <div style="background: #e5e7eb; height: 14px; border-radius: 999px;">
        {# Calcul du % en Twig #}
        {% set percent = totalOffres > 0 ? (ligne.nb / totalOffres * 100)|round : 0 %}
        <div style="height: 14px; width: {{ percent }}%; background: var(--accent); border-radius: 999px;"></div>
      </div>
      <div style="text-align: right;">{{ ligne.nb }}</div>
    </div>
  {% endfor %}
</section>
{% endblock %}