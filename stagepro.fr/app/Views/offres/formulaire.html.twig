{% extends "layout.html.twig" %}

{# Détection propre du mode édition #}
{% set isEdit = modeEdition|default(false) and offre is defined %}

{% block title %}
    {{ isEdit ? "Modifier l'offre" : "Publier une offre" }} | StagePro
{% endblock %}

{% block content %}
<div style="margin-bottom: 2rem;">
    <h1 style="color: #818cf8; margin-bottom: 0.5rem;">
        {{ isEdit ? "Modifier l'offre" : "Publier une nouvelle offre" }}
    </h1>
    <p style="color: var(--text-muted, #6b7280);">
        {{ isEdit ? "Ajustez les détails du poste pour les candidats." : "Remplissez les informations pour diffuser votre offre de stage." }}
    </p>
</div>

<div>
    {# CORRECTION : Le formulaire est maintenant dans une div neutre avec un fond blanc forcé #}
    <form action="index.php?page=offre-save" method="post" 
          style="max-width: 900px; background: #ffffff !important; padding: 2.5rem; border-radius: 12px; border: 1px solid var(--border, #e5e7eb); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin: 0 auto;">

        {# Champ caché pour l'ID en cas de modification #}
        {% if isEdit %}
            <input type="hidden" name="id" value="{{ offre.id }}">
        {% endif %}

        {# Grille adaptative #}
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">

            {# Titre (Toujours pleine largeur) #}
            <div style="grid-column: 1 / -1;">
                <label for="titre" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Intitulé du poste *</label>
                <input type="text" id="titre" name="titre" value="{{ offre.titre|default('') }}" 
                       placeholder="Ex: Développeur Web Fullstack H/F" required 
                       style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); background: #ffffff; color: #111827; box-sizing: border-box;">
            </div>

            {# Entreprise #}
            <div>
                <label for="id_entreprise" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Entreprise *</label>
                <select id="id_entreprise" name="id_entreprise" required 
                        style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); background: #ffffff; color: #111827; box-sizing: border-box;">
                    <option value="">-- Sélectionnez --</option>
                    {% for entreprise in entreprises %}
                        <option value="{{ entreprise.id }}" 
                            {{ (offre is defined and offre.id_entreprise == entreprise.id) ? 'selected' : '' }}>
                            {{ entreprise.nom }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Date #}
            <div>
                <label for="date_offre" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Date de publication *</label>
                <input type="date" id="date_offre" name="date_offre" 
                       value="{{ offre.date_offre|default("now"|date("Y-m-d")) }}" required 
                       style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); box-sizing: border-box; background: #ffffff;">
            </div>

            {# Localité #}
            <div>
                <label for="localite" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Ville / Lieu *</label>
                <input type="text" id="localite" name="localite" value="{{ offre.localite|default('') }}" 
                       placeholder="Ex: Lyon (69)" required 
                       style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); box-sizing: border-box; background: #ffffff;">
            </div>

            {# Durée #}
            <div>
                <label for="duree" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Durée du stage</label>
                <input type="text" id="duree" name="duree" value="{{ offre.duree|default('') }}" 
                       placeholder="Ex: 6 mois" 
                       style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); box-sizing: border-box; background: #ffffff;">
            </div>

            {# Nombre de places #}
            <div>
                <label for="nb_places" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Nombre de places *</label>
                <input type="number" id="nb_places" name="nb_places" min="1" value="{{ offre.nb_places|default('1') }}" required 
                       style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); box-sizing: border-box; background: #ffffff;">
            </div>

            {# Rémunération #}
            <div>
                <label for="remuneration" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Gratification mensuelle (€)</label>
                <input type="number" id="remuneration" name="remuneration" min="0" step="0.01" 
                       value="{{ offre.remuneration|default('') }}" placeholder="Ex: 600.00" 
                       style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); box-sizing: border-box; background: #ffffff;">
            </div>

            {# Compétences #}
            <div style="grid-column: 1 / -1;">
                <label for="competences" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Tags / Compétences clés</label>
                <input type="text" id="competences" name="competences" value="{{ offre.competences|default('') }}" 
                       placeholder="Ex: React, PHP, Docker..." 
                       style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border, #d1d5db); box-sizing: border-box; background: #ffffff;">
            </div>

            {# Description #}
            <div style="grid-column: 1 / -1;">
                <label for="description" style="display: block; margin-bottom: 0.5rem; font-weight: 600; color: #1e293b;">Description détaillée *</label>
                <textarea id="description" name="description" rows="8" placeholder="Détaillez les missions..." required 
                          style="width: 100%; padding: 1rem; border-radius: 8px; border: 1px solid var(--border, #d1d5db); background: #ffffff; color: #111827; font-family: inherit; line-height: 1.5; box-sizing: border-box;">{{ offre.description|default('') }}</textarea>
            </div>

        </div>

        {# Zone d'action #}
        <div style="margin-top: 2.5rem; display: flex; align-items: center; gap: 2rem; border-top: 1px solid var(--border, #e5e7eb); padding-top: 2rem; flex-wrap: wrap;">
            {# CORRECTION : Suppression des marqueurs de conflit Git #}
            <button type="submit" 
                    style="background: #2563eb; color: white; padding: 0.8rem 2.5rem; border: none; border-radius: 8px; cursor: pointer; font-weight: 700; font-size: 1rem; transition: background 0.2s;">
                {{ isEdit ? "Mettre à jour" : "Publier l'offre" }}
            </button>
            <a href="index.php?page=offres" style="color: var(--text-muted, #6b7280); text-decoration: none; font-size: 0.95rem; font-weight: 500;">
                Annuler
            </a>
        </div>

    </form>
</div>
{% endblock %}