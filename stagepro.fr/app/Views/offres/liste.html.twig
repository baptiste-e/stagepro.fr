{% extends "layout.html.twig" %}

{% block title %}Catalogue des offres | StagePro{% endblock %}

{% block content %}
<section>
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h1>Catalogue des offres</h1>
      <p style="color: var(--text-muted);">Explorez les opportunités de stage et propulsez votre carrière.</p>
    </div>
    <div style="display: flex; gap: 1rem;">
        <a href="index.php?page=offres-stats" class="btn-cta" style="background: var(--accent-purple);">📈 Statistiques</a>
        
        {# Bouton de création réservé Admin/Pilote #}
        {% if session.user and session.user.role in ['admin', 'pilote'] %}
          <a href="index.php?page=offre-create" class="btn-cta">+ Publier une offre</a>
        {% endif %}
    </div>
  </div>
</section>

{# --- SECTION FILTRES --- #}
<section style="margin-top: 2rem; background: var(--surface); padding: 2rem; border-radius: 12px; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
  <h2 style="margin-bottom: 1.5rem; font-size: 1.1rem; color: var(--accent-blue); text-transform: uppercase; letter-spacing: 0.05em;">Filtrer les résultats</h2>
  
  <form action="index.php" method="get">
    <input type="hidden" name="page" value="offres">
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
      <div class="form-group">
        <label for="titre" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Titre / Mot-clé</label>
        <input type="search" id="titre" name="titre" placeholder="Développeur..." value="{{ filters.titre|default('') }}" style="width: 100%; padding: 0.6rem; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--text);">
      </div>

      <div class="form-group">
        <label for="entreprise" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Entreprise</label>
        <input type="text" id="entreprise" name="entreprise" placeholder="Ex: TechCorp" value="{{ filters.entreprise|default('') }}" style="width: 100%; padding: 0.6rem; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--text);">
      </div>

      <div class="form-group">
        <label for="competences" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Compétences</label>
        <input type="text" id="competences" name="competences" placeholder="SQL, React..." value="{{ filters.competences|default('') }}" style="width: 100%; padding: 0.6rem; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--text);">
      </div>

      <div class="form-group">
        <label for="remuneration" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Gratification min. (€)</label>
        <input type="number" id="remuneration" name="remuneration" min="0" placeholder="Ex: 600" value="{{ filters.remuneration|default('') }}" style="width: 100%; padding: 0.6rem; border-radius: 6px; border: 1px solid var(--border); background: var(--background); color: var(--text);">
      </div>
    </div>

    <div style="margin-top: 1.5rem; display: flex; gap: 1rem; align-items: center;">
      <button type="submit" class="btn-cta" style="padding: 0.6rem 1.5rem;">🔍 Rechercher</button>
      <a href="index.php?page=offres" style="text-decoration: none; color: var(--text-muted); font-size: 0.9rem; font-weight: 500;">Effacer les filtres</a>
    </div>
  </form>
</section>

{# --- GRILLE DES OFFRES --- #}
<section style="margin-top: 3rem; margin-bottom: 5rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem;">
    {% for offre in offres %}
        <article class="card-offre" style="background: var(--surface); border: 1px solid var(--border); padding: 1.8rem; border-radius: 12px; display: flex; flex-direction: column; gap: 1rem; transition: all 0.2s ease; position: relative;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem;">
                <h3 style="font-size: 1.2rem; color: var(--accent-purple); margin: 0; line-height: 1.3;">{{ offre.titre }}</h3>
                
                {# Badge 'Récent' (si publié il y a moins de 3 jours) #}
                {% if offre.date_offre|date('U') > "now -3 days"|date('U') %}
                    <span style="font-size: 0.65rem; background: #4ade8020; color: #4ade80; padding: 3px 8px; border-radius: 20px; font-weight: 800; text-transform: uppercase; white-space: nowrap;">Nouveau</span>
                {% endif %}
            </div>
            
            <p style="font-weight: 700; font-size: 0.95rem; margin: 0; color: var(--text-main);">🏢 {{ offre.entreprise_nom|default('Entreprise inconnue') }}</p>
            
            <p style="font-size: 0.9rem; color: var(--text-muted); flex-grow: 1; line-height: 1.6;">
                {{ offre.description|slice(0, 140) }}...
            </p>
            
            <div style="margin-top: auto; border-top: 1px solid var(--border); padding-top: 1.2rem; display: flex; justify-content: space-between; align-items: center;">
                <div style="display: flex; flex-direction: column;">
                    <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Gratification</span>
                    <span style="font-size: 1rem; color: var(--accent-blue); font-weight: 800;">
                        {{ offre.remuneration ? offre.remuneration|number_format(2, ',', ' ') ~ ' €' : 'N/C' }}
                    </span>
                </div>
                
                <div style="display: flex; gap: 12px; align-items: center;">
                    {# Wishlist (Uniquement pour les étudiants) #}
                    {% if session.user and session.user.role == 'etudiant' %}
                        <form action="index.php?page=wishlist-add" method="post" style="margin: 0;">
                            <input type="hidden" name="id_offre" value="{{ offre.id }}">
                            <button type="submit" title="Ajouter aux favoris" style="background: none; border: 1px solid var(--border); padding: 5px 10px; border-radius: 6px; cursor: pointer; color: var(--text-muted); font-size: 0.8rem; transition: 0.2s;">
                                ☆
                            </button>
                        </form>
                    {% endif %}

                    <a href="index.php?page=offre-detail&id={{ offre.id }}" style="color: var(--accent-purple); font-size: 0.9rem; text-decoration: none; font-weight: 700;">Détails →</a>

                    {# Actions Administrateur #}
                    {% if session.user and session.user.role in ['admin', 'pilote'] %}
                        <div style="display: flex; gap: 8px; margin-left: 10px; border-left: 1px solid var(--border); padding-left: 12px;">
                            <a href="index.php?page=offre-edit&id={{ offre.id }}" title="Modifier" style="text-decoration: none;">✏️</a>
                            <a href="index.php?page=offre-delete&id={{ offre.id }}" 
                               style="text-decoration: none;" 
                               onclick="return confirm('Supprimer définitivement cette offre ?')" 
                               title="Supprimer">🗑️</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </article>
    {% else %}
        {# Affichage si aucun résultat #}
        <div style="grid-column: 1 / -1; text-align: center; padding: 5rem; color: var(--text-muted); background: var(--surface); border-radius: 12px; border: 1px dashed var(--border);">
            <p style="font-size: 1.1rem;">Aucune offre ne correspond à votre recherche actuelle.</p>
            <a href="index.php?page=offres" style="color: var(--accent-blue); display: block; margin-top: 1rem;">Voir toutes les offres</a>
        </div>
    {% endfor %}
  </div>
</section>

<style>
.card-offre:hover {
    transform: translateY(-5px);
    border-color: var(--accent-blue) !important;
    box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.1);
}
</style>
{% endblock %}