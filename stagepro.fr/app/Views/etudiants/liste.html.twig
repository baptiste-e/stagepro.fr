{% extends "layout.html.twig" %}

{% block title %}Annuaire des étudiants | StagePro{% endblock %}

{% block content %}
{# Utilisation de <div> au lieu de <section> pour éviter les marges de 5rem du CSS global #}
<div style="margin-bottom: 2rem;">
  <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
    <div>
      <h1>Annuaire des étudiants</h1>
      <p style="color: var(--text-muted, #6b7280);">Gérez les comptes et suivez l'avancement des recherches.</p>
    </div>

    {# Accès restreint au bouton de création (Admin/Pilote) #}
    {% if session.user and session.user.role in ['admin', 'pilote'] %}
      <a href="index.php?page=etudiant-create" class="btn-cta" style="font-size: 0.85rem;">+ Créer un étudiant</a>
    {% endif %}
  </div>
</div>

<div style="margin-top: 3rem;">
  <h2 style="margin-bottom: 1.5rem;">Liste des inscrits</h2>
  
  <div class="container-espaces" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
    {% for etudiant in etudiants %}
        
        {# CORRECTION : Remplacement de <article> par <div> pour éviter les styles gris parasites #}
        <div class="etudiant-card">
          <h3 style="color: var(--accent, #2563eb); margin-bottom: 0.8rem; font-size: 1.25rem;">
            {{ etudiant.prenom }} {{ etudiant.nom }}
          </h3>
          
          <div style="font-size: 0.95rem; color: var(--text-main, #1f2937); line-height: 1.6;">
            <p style="margin-bottom: 0.5rem;">
              <strong>Email :</strong> {{ etudiant.email }}
            </p>
            
            <p style="font-size: 0.85rem; color: var(--text-muted, #6b7280); margin-top: 1rem;">
              <strong>Inscrit le :</strong><br>
              {{ etudiant.created_at ? etudiant.created_at|date("d/m/Y à H:i") : 'Non renseignée' }}
            </p>
          </div>

          {# Lien étendu pour rendre toute la carte cliquable #}
          <a href="index.php?page=etudiant-detail&id={{ etudiant.id }}" class="lien-etendu" title="Voir le profil de {{ etudiant.prenom }}"></a>
        </div>
    {% else %}
        {# État vide si aucun étudiant n'est trouvé #}
        <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; background: #ffffff; border-radius: 12px; border: 1px dashed var(--border, #d1d5db);">
            <p style="color: var(--text-muted, #6b7280);">Aucun étudiant trouvé dans la base de données.</p>
        </div>
    {% endfor %}
  </div>
</div>

<style>
/* CORRECTION : Style forcé pour la carte étudiant (fond blanc pur) */
.etudiant-card {
    position: relative; 
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
    min-height: 180px;
    background: #ffffff !important; /* Force le blanc pur */
    border: 1px solid var(--border, #d1d5db); 
    border-radius: 12px; 
    padding: 1.5rem;
    text-decoration: none;
}

.etudiant-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent, #2563eb) !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1) !important;
}

.lien-etendu {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
}
</style>
{% endblock %}