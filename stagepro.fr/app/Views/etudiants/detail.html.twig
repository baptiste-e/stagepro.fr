{% extends "layout.html.twig" %}

{# Normalisation du rôle pour la sécurité de l'interface #}
{% set userRole = session.user.role_nom|default(session.user.role)|lower|trim %}

{% block title %}Profil de {{ etudiant.prenom }} {{ etudiant.nom }} | StagePro{% endblock %}

{% block content %}
{# Fil d’ariane #}
<nav aria-label="Fil d’ariane" style="margin-bottom: 2rem; font-size: 0.8rem;">
  <p>
    <a href="index.php?page=home" style="color: var(--accent, #2563eb); text-decoration: none;">Accueil</a> &gt;
    <a href="index.php?page=etudiants" style="color: var(--accent, #2563eb); text-decoration: none;">Étudiants</a> &gt;
    <span style="color: var(--text-muted, #6b7280);">Détail profil</span>
  </p>
</nav>

<div style="display: grid; grid-template-columns: 1fr 2.5fr; gap: 2rem; align-items: start;">

  {# --- COLONNE DE GAUCHE : INFOS --- #}
  <aside>
    <div style="background: #ffffff; border: 1px solid var(--border, #d1d5db); padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <div style="text-align: center; margin-bottom: 1.5rem;">
        {# Initiales #}
        <div style="width: 80px; height: 80px; background: var(--accent, #2563eb); border-radius: 50%; margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold; color: white;">
          {{ etudiant.prenom|slice(0,1)|upper }}{{ etudiant.nom|slice(0,1)|upper }}
        </div>
        <h2 style="font-size: 1.25rem; color: var(--text-main, #1f2937); margin-bottom: 0.25rem;">
            {{ etudiant.prenom }} {{ etudiant.nom }}
        </h2>
        <p style="font-size: 0.75rem; color: #9333ea; font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em;">Étudiant</p>
      </div>

      <ul style="list-style: none; font-size: 0.9rem; line-height: 1.8; padding: 0; margin: 0; color: var(--text-main, #1f2937);">
        <li style="margin-bottom: 1rem;">
            <strong style="color: var(--text-muted, #6b7280); font-size: 0.75rem; text-transform: uppercase;">Email</strong><br>
            <span style="word-break: break-all;">{{ etudiant.email|default('Non renseigné') }}</span>
        </li>
        <li style="margin-bottom: 1rem;">
            <strong style="color: var(--text-muted, #6b7280); font-size: 0.75rem; text-transform: uppercase;">Centre</strong><br>
            {{ etudiant.centre_nom|default('Non assigné') }}
        </li>
        <li>
            <strong style="color: var(--text-muted, #6b7280); font-size: 0.75rem; text-transform: uppercase;">Compte créé le</strong><br>
            {{ etudiant.created_at ? etudiant.created_at|date("d/m/Y à H:i") : 'Non renseignée' }}
        </li>
      </ul>

      {# Actions réservées (Admin/Pilote) #}
      {% if userRole == 'admin' or userRole == 'pilote' %}
      <div style="margin-top: 2rem; border-top: 1px solid var(--border, #d1d5db); padding-top: 1.5rem;">
        <a href="index.php?page=etudiant-edit&id={{ etudiant.id }}" 
           style="display: block; text-align: center; margin-bottom: 0.7rem; font-size: 0.85rem; text-decoration: none; background: #1e293b; color: white; padding: 0.7rem; border-radius: 6px; font-weight: bold; transition: opacity 0.2s;">
            Modifier le compte
        </a>

        <form action="index.php?page=etudiant-delete" method="post" style="margin: 0; padding: 0; border: none; background: transparent;" onsubmit="return confirm('Confirmer la suppression de cet étudiant ?');">
            <input type="hidden" name="id" value="{{ etudiant.id }}">
            <button type="submit" class="btn-delete-outline">
                Supprimer l'étudiant
            </button>
        </form>
      </div>
      {% endif %}
    </div>
  </aside>

  {# --- COLONNE DE DROITE : ACTIVITÉ --- #}
  <div>
    <div style="background: #ffffff; border: 1px solid var(--border, #d1d5db); padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
      <h2 style="margin-bottom: 1.5rem; color: var(--text-main, #1f2937); font-size: 1.3rem;">Candidatures / Activité</h2>

      <div style="display: flex; flex-direction: column; gap: 1rem;">
          
          {% if candidatures is defined and candidatures is not empty %}
              {% for c in candidatures %}
                  <div style="border: 1px solid var(--border, #d1d5db); padding: 1.5rem; border-radius: 8px; background: #ffffff;">
                      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                          <h3 style="font-size: 1.1rem; color: var(--accent, #2563eb); margin: 0;">{{ c.offre_titre }}</h3>
                          
                          <span style="font-size: 0.75rem; font-weight: bold; text-transform: uppercase; padding: 4px 10px; border-radius: 999px;
                              {% if c.statut == 'acceptee' %} background: #dcfce7; color: #166534;
                              {% elseif c.statut == 'refusee' %} background: #fee2e2; color: #991b1b;
                              {% else %} background: #fef3c7; color: #92400e; {% endif %}">
                              {{ c.statut|default('En attente')|replace({'_': ' '}) }}
                          </span>
                      </div>
                      
                      <p style="font-size: 0.9rem; color: var(--text-main, #334155); margin: 0 0 0.5rem 0;"><strong>Entreprise :</strong> {{ c.entreprise_nom }}</p>
                      <p style="font-size: 0.8rem; color: var(--text-muted, #6b7280); margin: 0;">Envoyée le : {{ c.created_at|date("d/m/Y") }}</p>
                      
                      <div style="margin-top: 1rem; text-align: right; border-top: 1px solid var(--border, #d1d5db); padding-top: 0.8rem;">
                          <a href="index.php?page=candidature-detail&id={{ c.id }}" style="font-size: 0.85rem; color: var(--accent, #2563eb); text-decoration: none; font-weight: 600;">Voir la candidature &rarr;</a>
                      </div>
                  </div>
              {% endfor %}
          {% else %}
              <div style="border: 1px solid var(--border, #d1d5db); padding: 2.5rem; border-radius: 8px; background: #f8fafc; text-align: center;">
                  <p style="font-size: 0.95rem; color: var(--text-muted, #6b7280); margin: 0;">
                      Aucune candidature n'est liée à ce profil pour le moment.
                  </p>
              </div>
          {% endif %}
          
      </div>
    </div>
  </div>

</div>

<style>
.btn-delete-outline {
    width: 100%; 
    background: transparent; 
    border: 1px solid #ef4444; 
    color: #ef4444; 
    font-size: 0.85rem; 
    cursor: pointer; 
    padding: 0.6rem; 
    border-radius: 6px; 
    font-weight: 600; 
    transition: all 0.2s;
}
.btn-delete-outline:hover {
    background: #ef4444 !important;
    color: #ffffff !important;
}
</style>
{% endblock %}