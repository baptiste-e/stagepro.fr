{% extends "layout.html.twig" %}

{% block title %}Ma Wish-list | StagePro{% endblock %}

{% block content %}
{# Fil d'Ariane #}
<nav aria-label="Fil d’ariane" style="margin-bottom: 2rem; font-size: 0.8rem;">
  <p>
    <a href="index.php?page=home" style="color: var(--accent-blue, #2563eb); text-decoration: none;">Accueil</a> &gt;
    <span style="color: var(--text-muted, #6b7280);">Ma wish-list</span>
  </p>
</nav>

<section>
    {# Vérification si la liste est vide #}
    {% if wishlist is empty %}
        <div style="background: var(--surface); padding: 4rem 2rem; border-radius: 12px; border: 1px dashed var(--border); text-align: center;">
            <div style="font-size: 4rem; margin-bottom: 1.5rem; opacity: 0.5;"></div>
            <h1 style="margin-bottom: 1rem;">Votre wish-list est vide</h1>
            <p style="color: var(--text-muted); margin-bottom: 2rem; font-size: 1.1rem;">Vous n'avez pas encore enregistré d'offres en favoris.</p>
            <a href="index.php?page=offres" class="btn-cta" style="padding: 0.8rem 2rem; text-decoration: none;">Explorer les offres</a>
        </div>
    {% else %}
        <h1 style="margin-bottom: 2rem;">Ma wish-list</h1>
        
        {# Grille des favoris #}
        <div class="container-espaces" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
            {% for item in wishlist %}
                
                {# CORRECTION 1 : On supprime la classe "card" qui créait le bug de clic et de couleur grise #}
                <article class="wishlist-card" style="display: flex; flex-direction: column; justify-content: space-between; background: var(--surface, #ffffff); border: 1px solid var(--border, #d1d5db); padding: 1.5rem; border-radius: 12px; transition: transform 0.2s;">
                    
                    <div>
                        <h3 style="color: var(--accent-blue, #2563eb); margin-bottom: 0.5rem; font-size: 1.2rem;">{{ item.titre }}</h3>
                        <p style="margin-bottom: 0.5rem; color: var(--text-main, #1f2937);"><strong> Entreprise :</strong> {{ item.entreprise_nom }}</p>
                        
                        {# Affichage de la date d'ajout #}
                        {% if item.wishlist_created_at %}
                            <p style="font-size: 0.85rem; color: var(--text-muted, #6b7280); margin-top: 0.8rem;">
                                 <strong>Ajoutée le :</strong> 
                                {{ item.wishlist_created_at|date('d/m/Y à H:i') }}
                            </p>
                        {% endif %}
                    </div>
                    
                    {# Actions #}
                    <div style="margin-top: 2rem; display: flex; gap: 12px; align-items: center; border-top: 1px solid var(--border, #d1d5db); padding-top: 1.2rem;">
                        
                        <a href="index.php?page=offre-detail&id={{ item.id }}" class="btn-cta" style="font-size: 0.8rem; text-decoration: none; padding: 0.6rem 1rem;">
                            Voir l'offre
                        </a>
                        
                        {# CORRECTION 2 : On reset les styles du <form> pour qu'il ne prenne pas le design des gros formulaires du CSS global #}
                        <form action="index.php?page=wishlist-remove" method="post" style="margin: 0; padding: 0; background: transparent; border: none;" onsubmit="return confirm('Retirer cette offre de vos favoris ?');">
                            <input type="hidden" name="id_offre" value="{{ item.id }}">
                            <button type="submit" style="background: transparent; border: 1px solid #ef4444; color: #ef4444; padding: 0.6rem 1rem; font-size: 0.8rem; cursor: pointer; border-radius: 6px; font-weight: 700; transition: all 0.2s;">
                                Retirer
                            </button>
                        </form>
                        
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</section>

<style>
.wishlist-card {
    height: auto !important; 
    min-height: 250px !important;
    overflow: visible !important;
    position: relative; /* Sécurise l'empilement */
    z-index: 10;
}
.wishlist-card:hover {
    transform: translateY(-5px);
    border-color: #2563eb !important; /* Utilisation de la couleur brute pour s'assurer que le hover marche */
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
}
/* Ajout d'un petit effet au survol du bouton supprimer */
.wishlist-card form button:hover {
    background: #ef4444 !important;
    color: #ffffff !important;
}
</style>
{% endblock %}